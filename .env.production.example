# Public DNS names already pointing to the Hostinger VPS.
STUDIO_DOMAIN=studio.example.com
DEMO_DOMAIN=demo.example.com

# Names from the VPS's existing Traefik deployment.
TRAEFIK_NETWORK=traefik
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_CERTRESOLVER=letsencrypt
# Existing Traefik auth or IP-allowlist middleware; do not store its secret here.
TRAEFIK_STUDIO_MIDDLEWARES=studio-auth@docker

# Use an immutable release label or git SHA for each deployment.
IMAGE_TAG=initial
WORKFLOW_VOLUME_NAME=visual-compiler-workflows

# Offline/mock compilation is the safe default and needs no OpenAI credential.
USE_LIVE_OPENAI=false
OPENAI_COMPILE_MODEL=gpt-5.6
OPENAI_API_KEY=
